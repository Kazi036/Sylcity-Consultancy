generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Consultation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  service   String
  country   String?  
  message   String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  

  @@map("consultation") 
}